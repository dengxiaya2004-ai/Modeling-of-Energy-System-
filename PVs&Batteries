class Dispatcher:
    """
    Hourly rule-based energy management system.

    Dispatch logic
    ──────────────
    Operating hours (08:00–17:59):
      1. PV AC output → directly to load (up to demand)
      2. PV surplus   → charge battery
      3. Remaining demand → discharge battery
      4. Any remaining gap → flagged as 'unmet' (covered by other subsystems)

    Non-operating hours:
      1. PV surplus → charge battery (no load)
      2. PV excess beyond battery capacity → curtailed
    """

    def __init__(self, pv: PVArray, battery: BatteryESS, inverter: Inverter,
                 coverage_frac: float = 0.40):
        self.pv            = pv
        self.battery       = battery
        self.inverter      = inverter
        self.coverage_frac = coverage_frac

    # ------------------------------------------------------------------
    def run(self, ghi: np.ndarray, t_amb: np.ndarray,
            total_demand_kw: np.ndarray, operating_hours: np.ndarray,
            year: int = 1) -> pd.DataFrame:
        """
        Simulate one full year (8 760 hourly time-steps).

        Parameters
        ----------
        ghi             : Global Horizontal Irradiance  [W/m²]  (8760,)
        t_amb           : Ambient temperature           [°C]    (8760,)
        total_demand_kw : Total plant heat demand       [kW]    (8760,)
        operating_hours : Boolean mask, True = plant on        (8760,)
        year            : Operational year (affects degradation)

        Returns
        -------
        pd.DataFrame with hourly energy flows and KPIs
        """
        n   = len(ghi)
        pv_dc  = self.pv.dc_power_kw(ghi, t_amb, year)
        pv_ac  = self.inverter.ac_power_kw(pv_dc)
        target = total_demand_kw * self.coverage_frac

        cols = ["pv_dc_kw", "pv_ac_kw", "target_kw",
                "pv_to_load_kw", "bat_to_load_kw",
                "p_charge_kw", "p_discharge_kw",
                "unmet_kw", "curtailed_kw",
                "soc_kwh", "soc_pct"]
        data = {c: np.zeros(n) for c in cols}
        data["pv_dc_kw"][:] = pv_dc
        data["pv_ac_kw"][:] = pv_ac
        data["target_kw"][:] = target

        self.battery.reset(initial_soc=0.50)

        for t in range(n):
            pv = pv_ac[t]
            dm = target[t]
            op = operating_hours[t]

            if not op:
                # Off hours: charge battery with any available PV
                if pv > 0:
                    b = self.battery.step(-pv, dt=1.0)
                    data["p_charge_kw"][t]  = b["p_charge_kw"]
                    data["curtailed_kw"][t] = max(pv - b["p_charge_kw"], 0.0)
                else:
                    b = self.battery.step(0.0, dt=1.0)
                data["soc_kwh"][t] = b["soc_kwh"]
                data["soc_pct"][t] = b["soc_pct"]
                continue

            # Step 1 – PV directly to load
            pv2load = min(pv, dm)
            surplus  = pv - pv2load
            remain   = dm - pv2load
            data["pv_to_load_kw"][t] = pv2load

            # Step 2 – surplus PV charges battery
            if surplus > 0:
                b = self.battery.step(-surplus, dt=1.0)
                data["p_charge_kw"][t]  = b["p_charge_kw"]
                data["curtailed_kw"][t] = max(surplus - b["p_charge_kw"], 0.0)
                soc_kwh = b["soc_kwh"]
                soc_pct = b["soc_pct"]
            else:
                soc_kwh = self.battery.soc_kwh
                soc_pct = self.battery.soc_pct

            # Step 3 – discharge battery to meet remaining demand
            if remain > 0:
                b = self.battery.step(remain, dt=1.0)
                data["p_discharge_kw"][t] = b["p_discharge_kw"]
                data["bat_to_load_kw"][t] = b["p_discharge_kw"]
                data["unmet_kw"][t]       = max(remain - b["p_discharge_kw"], 0.0)
                soc_kwh = b["soc_kwh"]
                soc_pct = b["soc_pct"]

            data["soc_kwh"][t] = soc_kwh
            data["soc_pct"][t] = soc_pct

        df = pd.DataFrame(data)
        df["delivered_kw"]    = df["pv_to_load_kw"] + df["bat_to_load_kw"]
        df["actual_cov_pct"]  = np.where(
            df["target_kw"] > 0,
            df["delivered_kw"] / df["target_kw"] * 100.0, 0.0)
        df["hour_of_day"]     = np.arange(n) % 24
        df["day_of_year"]     = np.arange(n) // 24 + 1
        df["ghi_wm2"]         = ghi
        df["t_amb_c"]         = t_amb
        df["total_demand_kw"] = total_demand_kw
        df["operating"]       = operating_hours
        return df


