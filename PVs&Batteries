@dataclass
class JinkoTigerNeo:
    """
    Jinko Solar Tiger Neo 72HL4-BDV  (ENF Crystalline Panel #55991)
    Bifacial N-type TOPCon, dual glass, 182 mm M10 cells
    Datasheet: JKM575-600N-72HL4-BDV
    """
    model: str          = "JKM590N-72HL4-BDV"
    pmax_stc: float     = 590.0     # W  – STC peak power (mid-range 575-600 W)
    vmp_stc: float      = 44.1      # V  – voltage at max power
    imp_stc: float      = 13.38     # A  – current at max power
    voc_stc: float      = 52.80     # V  – open-circuit voltage
    isc_stc: float      = 14.20     # A  – short-circuit current
    eta_stc: float      = 0.2265    # –  – module efficiency 22.65 %
    gamma_pmax: float   = -0.0029   # /°C – temperature coeff of Pmax (–0.29 %/°C)
    noct: float         = 45.0      # °C – nominal operating cell temperature
    width_m: float      = 1.134     # m
    length_m: float     = 2.278     # m
    deg_y1: float       = 0.010     # fraction – first-year degradation < 1 %
    deg_annual: float   = 0.004     # fraction – annual degradation 0.4 %/yr (years 2+)
    warranty_product: int = 12      # years
    warranty_power: int   = 30      # years
    cost_eur_per_wp: float = 0.25   # €/Wp  (indicative utility-scale 2023)
    bifaciality: float  = 0.70      # rear-side gain factor (not used in base case)

    @property
    def area_m2(self) -> float:
        return self.width_m * self.length_m  # 2.579 m²


@dataclass
class SungrowModular:
    """
    Sungrow 1+X Modular Inverter  (SG1100UD-20)
    Each module: 1 100 kW,  up to 8 modules in parallel = 8.8 MW block
    Max efficiency > 99 %
    """
    model: str              = "SG1100UD-20"
    power_module_kw: float  = 1_100.0   # kW per module
    eta_max: float          = 0.990     # peak efficiency
    eta_euro: float         = 0.988     # Euro weighted efficiency
    max_modules: int        = 8         # hard limit from datasheet
    cost_eur_per_kw: float  = 45.0      # €/kW  (utility scale)
    lifetime_yr: int        = 25        # years

    def modules_needed(self, target_kw: float) -> int:
        n = int(np.ceil(target_kw / self.power_module_kw))
        return min(n, self.max_modules)

    def rated_power_kw(self, target_kw: float) -> float:
        return self.modules_needed(target_kw) * self.power_module_kw


@dataclass
class TeslaMegapack2XL:
    """
    Tesla Megapack 2 XL – 4-hour configuration
    Datasheet Rev. 1.5.1 – February 10, 2023
    Source: portal.ct.gov (PE1607 Supplement Attachment A)
    """
    model: str              = "Megapack 2 XL (4h)"
    energy_kwh: float       = 3_916.0   # kWh AC energy per unit
    power_kw: float         = 979.0     # kW  AC power per unit
    rte: float              = 0.937     # round-trip efficiency 93.7 %
    voltage_v: float        = 480.0     # V AC nominal (3-phase)
    min_soc: float          = 0.05      # 5 %  – minimum state of charge
    max_soc: float          = 0.95      # 95 % – maximum state of charge
    self_discharge_hr: float = 0.00005  # fraction per hour (LFP ≈ 0.005 %/h)
    warranty_yr: int        = 15        # standard warranty (extendable to 20)
    cost_eur_per_kwh: float = 280.0     # €/kWh  (indicative 2023)
    cost_eur_per_kw: float  = 0.0       # included in per-kWh figure for BESS
    cycles_lifetime: int    = 3_000     # approximate cycle life

    @property
    def charge_eta(self) -> float:
        return np.sqrt(self.rte)

    @property
    def discharge_eta(self) -> float:
        return np.sqrt(self.rte)

    def units_for_energy(self, kwh: float) -> int:
        usable = self.energy_kwh * (self.max_soc - self.min_soc)
        return int(np.ceil(kwh / usable))

    def units_for_power(self, kw: float) -> int:
        return int(np.ceil(kw / self.power_kw))

    def units_needed(self, kwh: float, kw: float) -> int:
        return max(self.units_for_energy(kwh), self.units_for_power(kw))


