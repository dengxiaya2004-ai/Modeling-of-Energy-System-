def main(pvgis_path: Optional[str] = None):
    SEP = "─" * 68

    # ── Component specs ───────────────────────────────────────────────
    panel_spec   = JinkoTigerNeo()
    battery_spec = TeslaMegapack2XL()
    inverter_spec = SungrowModular()

    # ── System sizing ─────────────────────────────────────────────────
    #
    #  Total plant demand  : 10 MW  (08:00–18:00)
    #  PV+Bat coverage     : 40 %   → 4 MW target
    #  Storage duration    : 4 h    → 16 MWh battery
    #  PV oversizing factor: 1.6×   (charge battery AND meet midday demand)
    #    Reasoning: Seville PSH ≈ 5.5 h/day; need 4 MW × 10 h = 40 MWh/day
    #    PV peak ≈ 40 MWh / (5.5 h × 0.86 losses) ≈ 8.5 MWp

    TOTAL_MW      = 10.0
    COVERAGE      = 0.40
    TARGET_MW     = TOTAL_MW * COVERAGE       # 4 MW
    STORAGE_HRS   = 4.0

    PV_PEAK_MWP   = 8.5                       # MWp
    BAT_ENERGY_KWH = TARGET_MW * 1_000 * STORAGE_HRS  # 16 000 kWh
    BAT_POWER_KW   = TARGET_MW * 1_000                 # 4 000 kW

    n_panels  = int(np.ceil(PV_PEAK_MWP * 1e6 / panel_spec.pmax_stc))
    n_bat     = battery_spec.units_needed(BAT_ENERGY_KWH, BAT_POWER_KW)
    n_inv     = inverter_spec.modules_needed(PV_PEAK_MWP * 1_000)

    # Instantiate
    pv_system  = PVArray(panel_spec, n_panels)
    bat_system = BatteryESS(battery_spec, n_bat)
    inv_system = Inverter(inverter_spec, n_inv)

    # ── Print sizing ──────────────────────────────────────────────────
    print(f"\n{SEP}")
    print(f"  MJ2438 – PV + Battery Subsystem  |  Seville, Spain")
    print(f"{SEP}")
    print(f"\n  COMPONENT SIZING")
    print(f"  {'PV Array':<20}: {n_panels:,} panels × {panel_spec.pmax_stc:.0f} W  "
          f"= {pv_system.peak_kw/1000:.2f} MWp  "
          f"({pv_system.area_m2/1000:.1f} km² collector area)")
    print(f"  {'Battery':<20}: {n_bat} × Tesla Megapack 2 XL  "
          f"= {n_bat * battery_spec.energy_kwh / 1000:.1f} MWh  "
          f"| {n_bat * battery_spec.power_kw / 1000:.2f} MW  "
          f"(RTE = {battery_spec.rte*100:.1f} %)")
    print(f"  {'Inverter':<20}: {n_inv} × Sungrow 1.1 MW  "
          f"= {n_inv * inverter_spec.power_module_kw / 1000:.1f} MW")

    # ── Weather ───────────────────────────────────────────────────────
    # Priority: CLI --pvgis flag  >  TMY_FILE constant  >  synthetic fallback
    weather_file = pvgis_path or TMY_FILE
    try:
        ghi, t_amb = load_pvgis_tmy(weather_file)
        print(f"\n  Weather: PVGIS TMY data loaded  ← {weather_file}")
        print(f"  Annual GHI = {ghi.sum()/1000:.0f} kWh/m²  |  "
              f"Mean T_amb = {t_amb.mean():.1f} °C")
    except FileNotFoundError:
        print(f"\n  ⚠  TMY file '{weather_file}' not found — falling back to synthetic TMY.")
        print(f"  Set TMY_FILE at the top of the script to your PVGIS CSV filename.")
        ghi, t_amb = generate_synthetic_tmy()
        print(f"  Weather: Synthetic TMY (Seville, 37.4°N)  "
              f"— annual GHI ≈ {ghi.sum()/1000:.0f} kWh/m²")

    # ── Demand profile ────────────────────────────────────────────────
    hours         = np.arange(8_760)
    hour_of_day   = hours % 24
    op_mask       = (hour_of_day >= 8) & (hour_of_day < 18)
    demand_kw     = np.where(op_mask, TOTAL_MW * 1_000, 0.0)

    # ── Dispatch simulation ───────────────────────────────────────────
    dispatcher = Dispatcher(pv_system, bat_system, inv_system, COVERAGE)
    df = dispatcher.run(ghi, t_amb, demand_kw, op_mask, year=1)
    df["ghi_wm2"]       = ghi
    df["t_amb_c"]       = t_amb
    df["total_demand_kw"] = demand_kw

    # ── Economic analysis ─────────────────────────────────────────────
    econ    = EconomicModel(pv_system, bat_system, inv_system,
                            panel_spec, battery_spec, inverter_spec)
    summary = econ.full_summary(df)

    # ── Print results ─────────────────────────────────────────────────
    print(f"\n{SEP}")
    print(f"  CAPEX BREAKDOWN")
    print(f"{SEP}")
    for k, v in summary["CAPEX"].items():
        bar = "█" * int(v / summary["CAPEX"]["Total CAPEX"] * 30)
        print(f"  {k:<38}: € {v:>12,.0f}  {bar}")

    print(f"\n{SEP}")
    print(f"  ANNUAL OPEX")
    print(f"{SEP}")
    for k, v in summary["Annual OPEX"].items():
        print(f"  {k:<38}: € {v:>10,.0f} / yr")

    print(f"\n{SEP}")
    print(f"  KEY PERFORMANCE INDICATORS")
    print(f"{SEP}")
    for k, v in summary["KPIs"].items():
        print(f"  {k:<45}: {v:>10.2f}")
    print(f"\n{SEP}\n")

    # ── Save CSV ──────────────────────────────────────────────────────
    df.to_csv("hourly_results.csv", index=False)
    print("  → Hourly results saved: hourly_results.csv")

    # ── Plots ─────────────────────────────────────────────────────────
    plot_system_results(df, summary,
                        pv_peak_mwp=pv_system.peak_kw / 1_000,
                        bat_mwh=bat_system.capacity_kwh / 1_000,
                        n_bat_units=n_bat)

    # ── Sensitivity analysis ──────────────────────────────────────────
    print("  Running 2-D sensitivity analysis (LCOE & CAPEX)…")
    annual_del = df["delivered_kw"].sum()   # kWh
    pv_g, bat_g, lcoe_m, capex_m = sensitivity_analysis(
        base_pv_mwp            = pv_system.peak_kw / 1_000,
        base_bat_mwh           = bat_system.capacity_kwh / 1_000,
        panel_spec             = panel_spec,
        battery_spec           = battery_spec,
        inverter_spec          = inverter_spec,
        base_annual_energy_kwh = annual_del,
    )
    plot_sensitivity_results(pv_g, bat_g, lcoe_m, capex_m,
                             pv_system.peak_kw / 1_000,
                             bat_system.capacity_kwh / 1_000)

    return df, summary, econ


