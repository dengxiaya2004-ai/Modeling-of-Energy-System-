class Inverter:
    """
    Sungrow 1+X modular inverter efficiency model.
    Efficiency is approximated as a function of loading ratio.
    """

    def __init__(self, spec: SungrowModular, n_modules: int):
        self.spec      = spec
        self.n_modules = n_modules
        self.rated_kw  = spec.power_module_kw * n_modules

    # ------------------------------------------------------------------
    def ac_power_kw(self, dc_kw: np.ndarray) -> np.ndarray:
        """
        Convert DC → AC through the inverter efficiency curve.
        Three-segment model based on typical central-inverter curves:
          • < 5 % load  : below cut-in, output = 0
          • 5 – 20 % load: ramp from 0.960 to η_euro
          • > 20 % load : η = η_euro (≈ 98.8 %)
        """
        ratio = np.clip(dc_kw / self.rated_kw, 0.0, 1.10)
        eta   = np.where(
            ratio < 0.05,
            0.0,
            np.where(
                ratio < 0.20,
                0.960 + (self.spec.eta_euro - 0.960) * (ratio - 0.05) / 0.15,
                self.spec.eta_euro,
            ),
        )
        return np.maximum(dc_kw * eta, 0.0)


