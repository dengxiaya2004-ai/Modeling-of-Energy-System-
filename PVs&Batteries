        "--pvgis", metavar="CSV", default=None,
        help="Path to PVGIS TMY CSV for Seville. "
             "Download: https://re.jrc.ec.europa.eu/pvg_tools/en/#TMY "
             "(lat=37.39, lon=-5.99)",
    )
    args = parser.parse_args()
    main(pvgis_path=args.pvgis)
