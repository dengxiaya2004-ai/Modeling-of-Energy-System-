class PVArray:
    """
    High-fidelity PV array model using pvlib.

    Physical improvements vs. the baseline irradiance–temperature model
    ───────────────────────────────────────────────────────────────────
    1. POA irradiance  – Hay-Davies transposition (DNI + DHI + GHI from TMY).
    2. Row shading     – pvlib.shading.shaded_fraction1d on beam component.
    3. Spectral corr.  – SAPM factor (monosi) as f(absolute air mass, pressure).
    4. Bifacial gain   – Rear irradiance via simplified Marion et al. model.
    5. Cell temperature– Faiman (IEC 61853) model using TMY wind speed.
    6. DC power        – pvlib PVWatts v5 with spectral-corrected eff. irr.
    7. Degradation     – Linear within Year 1; cumulative from Year 2.
    8. DC voltage      – Temperature-corrected Vmp × n_series per string.
    """

    # SAPM spectral mismatch coefficients for monocrystalline Si
    # (Sandia National Laboratories, c-Si monosi module database)
    _SAPM_MONOSI = {
        "A0":  0.918093,
        "A1":  0.086257,
        "A2": -0.024459,
        "A3":  0.002816,
        "A4": -0.000126,
    }

    def __init__(
        self,
        panel: JinkoTigerNeo,
        n_panels: int,
        tilt_deg: float  = 30.0,     # array tilt (30° optimal for Seville)
        azimuth_deg: float = 180.0,  # south-facing
        gcr: float       = 0.40,     # ground coverage ratio
        albedo: float    = 0.25,     # ground reflectance (dry grass/soil)
        n_series: int    = 20,       # panels per string (sets DC voltage level)
        site: pvlib.location.Location = SEVILLE,
    ):
        self.panel    = panel
        self.n_panels = n_panels
        self.tilt     = tilt_deg
        self.azimuth  = azimuth_deg
        self.gcr      = gcr
        self.albedo   = albedo
        self.n_series = n_series
        self.site     = site

        self.peak_kw = panel.pmax_stc * n_panels / 1_000
        self.area_m2 = panel.area_m2  * n_panels

        # ── Pre-compute row geometry constants ────────────────────────
        # pvlib shading uses: pitch = collector_width / GCR  (axis-to-axis)
        self._collector_width = panel.length_m          # slant height [m]
        self._pitch           = panel.length_m / gcr   # axis-to-axis [m]

    # ─────────────────────────────────────────────────────────────────
    def _compute_beam_shading(
        self, solar_zenith: pd.Series, solar_azimuth: pd.Series
    ) -> np.ndarray:
        """
        Row-to-row beam-shading fraction using pvlib.shading.shaded_fraction1d.

        Model: Anderson & Jensen (2024), infinite south-facing fixed-tilt rows.
        Shading is applied only to the beam (direct) POA component; diffuse
        and ground-reflected components are assumed isotropic (unshaded).

        Returns
        -------
        shaded_fraction : np.ndarray in [0, 1]
            0 = no shading,  1 = row fully in shadow.
        """
        sf = pvl_shd.shaded_fraction1d(
            solar_zenith        = solar_zenith,
            solar_azimuth       = solar_azimuth,
            axis_azimuth        = 90.0,          # East-West row axis
            shaded_row_rotation = self.tilt,
            shading_row_rotation= self.tilt,     # identical rows
            collector_width     = self._collector_width,
            pitch               = self._pitch,
            axis_tilt           = 0.0,
        )
        return np.asarray(sf, dtype=float)

    # ─────────────────────────────────────────────────────────────────
    def _compute_spectral_factor(
        self, airmass_abs: pd.Series, poa_global: pd.Series
    ) -> np.ndarray:
        """
        SAPM spectral mismatch factor for monocrystalline silicon.

        f1(AM) = A0 + A1·AM + A2·AM² + A3·AM³ + A4·AM⁴

        Returns 0.0 where there is no irradiance (night-time).
        Output is clipped to [0.8, 1.2] to prevent unphysical extremes
        at very high air-mass values near the horizon.
        """
        sf = pvl_spec.spectral_factor_sapm(
            airmass_absolute = airmass_abs.fillna(0.0).clip(0.0, 10.0),
            module           = self._SAPM_MONOSI,
        )
        sf = np.clip(np.asarray(sf, dtype=float), 0.8, 1.2)
        # Zero spectral factor at night (no irradiance → no meaningful AM)
        sf = np.where(poa_global.values <= 0.0, 0.0, sf)
        return sf

    # ─────────────────────────────────────────────────────────────────
    def _compute_bifacial_rear_irr(self, ghi: pd.Series) -> pd.Series:
        """
        Rear-side irradiance using the simplified Marion et al. (2017)
        infinite-sheds view-factor model:

            G_rear ≈ albedo × GHI × (1 – GCR)

        The factor (1 – GCR) approximates the fraction of the ground
        visible from the rear of the panel that is not shaded by the
        module itself.  This is multiplied by the bifaciality factor
        in `simulate()` before adding to the front POA.

        Returns G_rear [W/m²].
        """
        return (self.albedo * ghi * (1.0 - self.gcr)).clip(lower=0.0)

    # ─────────────────────────────────────────────────────────────────
    def _compute_degradation(
        self, year: int, n_hours: int
    ) -> np.ndarray:
        """
        Continuous degradation factor array for the simulation year.

        Year 1 : linear interpolation from 1.0 (hour 0) to (1 – deg_y1)
                 (hour 8 759).  Represents the gradual LID / LeTID burn-in
                 of TOPCon panels over the first 12 months.
        Year 2+: uniform factor = (1–deg_y1) × (1–deg_annual)^(year–1).
        """
        if year == 1:
            t_frac = np.linspace(0.0, 1.0, n_hours)
            return 1.0 - self.panel.deg_y1 * t_frac
        else:
            factor = ((1.0 - self.panel.deg_y1)
                      * (1.0 - self.panel.deg_annual) ** (year - 1))
            return np.full(n_hours, factor, dtype=float)

    # ─────────────────────────────────────────────────────────────────
    def simulate(
        self, weather: pd.DataFrame, year: int = 1
    ) -> Tuple[np.ndarray, np.ndarray, pd.DataFrame]:
        """
        Run the full pvlib-enhanced PV simulation for one year.

        Parameters
        ----------
        weather : pd.DataFrame with DatetimeIndex (UTC) and columns:
                  'ghi'  [W/m²], 'dni' [W/m²], 'dhi'  [W/m²],
                  'temp_air' [°C], 'wind_speed' [m/s], 'pressure' [Pa]
        year    : operational year, 1-based (affects degradation)

        Returns
        -------
        dc_kw  : np.ndarray – total DC array output       [kW]
        v_dc   : np.ndarray – DC string voltage (MPPT)    [V]
        diag   : pd.DataFrame – intermediate diagnostics  (same index as weather)
        """
        n = len(weather)

        # ── A. Solar position (pvlib ephemeris) ───────────────────────
        solpos  = self.site.get_solarposition(weather.index)
        zenith  = solpos["apparent_zenith"]
        azimuth = solpos["azimuth"]

        # ── B. Extraterrestrial radiation (required by Hay-Davies) ────
        dni_extra = pvl_irr.get_extra_radiation(weather.index)

        # ── C. Airmass: relative → absolute (uses TMY pressure) ───────
        airmass_rel = pvl_atm.get_relative_airmass(
            zenith, model="kastenyoung1989")
        pressure    = weather.get(
            "pressure", pd.Series(101_325.0, index=weather.index))
        airmass_abs = pvl_atm.get_absolute_airmass(airmass_rel, pressure)

        # ── D. POA irradiance – Hay-Davies transposition ──────────────
        # This model uses DNI and DHI from the TMY (more accurate than using
        # GHI alone and an isotropic diffuse assumption).
        poa = pvl_irr.get_total_irradiance(
            surface_tilt    = self.tilt,
            surface_azimuth = self.azimuth,
            solar_zenith    = zenith,
            solar_azimuth   = azimuth,
            dni             = weather["dni"],
            ghi             = weather["ghi"],
            dhi             = weather["dhi"],
            dni_extra       = dni_extra,
            airmass         = airmass_rel,
            model           = "haydavies",
            albedo          = self.albedo,
        )
        poa_beam   = poa["poa_direct"].fillna(0.0).clip(lower=0.0)
        poa_sky    = poa["poa_sky_diffuse"].fillna(0.0).clip(lower=0.0)
        poa_ground = poa["poa_ground_diffuse"].fillna(0.0).clip(lower=0.0)

        # ── E. Row-to-row beam shading (pvlib shaded_fraction1d) ──────
        # Only the beam (direct) component is shaded; diffuse is treated
        # as isotropic and assumed unaffected.
        shade_frac  = self._compute_beam_shading(zenith, azimuth)
        poa_beam_sh = poa_beam * (1.0 - shade_frac)   # shading-reduced beam

        # Front-side effective POA (before spectral / bifacial corrections)
        poa_front = poa_beam_sh + poa_sky + poa_ground

        # ── F. SAPM spectral correction for monocrystalline Si ────────
        # Uses absolute airmass derived from TMY pressure (step C).
        # Accounts for the fact that module spectral response does not match
        # the AM1.5 reference equally at all airmass values.
        spectral_factor = self._compute_spectral_factor(airmass_abs, poa_front)

        # ── G. Bifacial rear-side irradiance gain ─────────────────────
        # Rear surface of the bifacial panel receives reflected irradiance
        # from the ground.  The bifaciality factor (η_rear/η_front = 0.70)
        # converts rear irradiance to an equivalent front-side contribution.
        g_rear        = self._compute_bifacial_rear_irr(weather["ghi"])
        poa_bifacial  = poa_front + self.panel.bifaciality * g_rear
        poa_bifacial  = poa_bifacial.clip(lower=0.0)

        # ── H. Cell temperature – Faiman / IEC 61853 model ───────────
        # Uses TMY wind speed (WS10m) for convective cooling.
        # u0 = 25 W/(m²·°C) – conductive/radiative heat loss coefficient.
        # u1 = 6.84 W·s/(m³·°C) – wind-dependent heat loss coefficient.
        # These are the IEC 61853-2 default values for free-standing modules.
        wind = weather.get("wind_speed",
                           pd.Series(1.0, index=weather.index))
        t_cell = pvl_temp.faiman(
            poa_global = poa_bifacial,
            temp_air   = weather["temp_air"],
            wind_speed = wind,
            u0         = 25.0,
            u1         = 6.84,
        )

        # ── I. Effective irradiance (spectral-corrected) ──────────────
        # This is the irradiance seen by the cell after accounting for
        # the spectral mismatch between the incident spectrum and the
        # module's spectral response.
        poa_effective = poa_bifacial * spectral_factor

        # ── J. DC power – pvlib PVWatts v5 model ──────────────────────
        # P_dc = G_eff/1000 * Pdc0 * [1 + γ_pmax * (T_cell – T_ref)]
        p_dc_per_panel = pvlib.pvsystem.pvwatts_dc(
            effective_irradiance = poa_effective,
            temp_cell            = t_cell,
            pdc0                 = self.panel.pmax_stc,  # W/panel at STC
            gamma_pdc            = self.panel.gamma_pmax,  # /°C
            temp_ref             = 25.0,
        ).fillna(0.0).clip(lower=0.0)

        # ── K. Degradation: continuous profile ────────────────────────
        deg_factor = self._compute_degradation(year, n)
        dc_kw = p_dc_per_panel.values * self.n_panels * deg_factor / 1_000

        # ── L. DC string voltage (temperature-corrected Vmp) ──────────
        # V_mp(T) = V_mp_STC × [1 + γ_Vmp × (T_cell – T_ref)]
        # Voltage is tracked per-string and used by the inverter MPPT model.
        v_mp_cell = (self.panel.vmp_stc
                     * (1.0 + self.panel.gamma_vmp * (t_cell - 25.0)))
        v_dc = (v_mp_cell * self.n_series).fillna(
            self.panel.vmp_stc * self.n_series).clip(lower=0.0).values

        # ── M. Diagnostics DataFrame ───────────────────────────────────
        diag = pd.DataFrame({
            # Irradiance breakdown
            "poa_beam_unshaded"  : poa_beam.values,
            "poa_beam_shaded"    : poa_beam_sh.values,
            "poa_sky_diffuse"    : poa_sky.values,
            "poa_ground_diffuse" : poa_ground.values,
            "poa_front"          : poa_front.values,
            "rear_irradiance_wm2": g_rear.values,
            "poa_bifacial"       : poa_bifacial.values,
            "poa_effective"      : poa_effective.values,
            # Correction factors
            "shade_fraction"     : shade_frac,
            "spectral_factor"    : spectral_factor,
            "bifacial_gain_wm2"  : (self.panel.bifaciality * g_rear).values,
            # Thermal
            "t_cell_c"           : t_cell.values,
            # Electrical
            "v_dc_v"             : v_dc,
            "dc_kw"              : dc_kw,
            "deg_factor"         : deg_factor,
        }, index=weather.index)

        return dc_kw, v_dc, diag

    # ─────────────────────────────────────────────────────────────────
    def annual_summary(self) -> dict:
        return {
            "n_panels"      : self.n_panels,
            "peak_kWp"      : round(self.peak_kw, 2),
            "area_m2"       : round(self.area_m2, 1),
            "tilt_deg"      : self.tilt,
            "gcr"           : self.gcr,
            "albedo"        : self.albedo,
            "n_series"      : self.n_series,
        }


# ──────────────────────────────────────────────────────────────────────────────
# 4.  BATTERY ENERGY STORAGE SYSTEM  (unchanged from baseline)
# ──────────────────────────────────────────────────────────────────────────────

class BatteryESS:
    """
    Rule-based hourly model for the Tesla Megapack 2 XL battery system.

    Dispatch priority
    ─────────────────
    Charging   : PV surplus  → battery
    Discharging: battery     → unmet demand
    """

    def __init__(self, spec: TeslaMegapack2XL, n_units: int):
        self.spec    = spec
        self.n_units = n_units

        self.capacity_kwh = spec.energy_kwh * n_units
        self.max_p_kw     = spec.power_kw   * n_units
        self.eta_ch       = spec.charge_eta
        self.eta_dis      = spec.discharge_eta

        self.min_e = self.capacity_kwh * spec.min_soc
        self.max_e = self.capacity_kwh * spec.max_soc

        self.ramp_limit_kw = self.max_p_kw * 0.20   # conservative ramp

        self._soc_kwh = self.capacity_kwh * 0.50
        self._prev_p  = 0.0

    @property
    def soc_kwh(self) -> float:
        return self._soc_kwh

    @property
    def soc_pct(self) -> float:
        return self._soc_kwh / self.capacity_kwh * 100.0

    def reset(self, initial_soc: float = 0.50):
        self._soc_kwh = self.capacity_kwh * initial_soc
        self._prev_p  = 0.0

    def step(self, net_demand_kw: float, dt: float = 1.0) -> dict:
        """
        Simulate one time-step.

        Parameters
        ----------
        net_demand_kw : positive = discharge needed; negative = surplus (charge)
        dt            : time-step length [h]
        """
        p_charge = p_discharge = 0.0

        if net_demand_kw < 0:
            surplus  = -net_demand_kw
            p_req    = min(surplus, self.max_p_kw)
            p_req    = min(p_req, self._prev_p + self.ramp_limit_kw)
            headroom = (self.max_e - self._soc_kwh) / (self.eta_ch * dt)
            p_charge = min(p_req, max(headroom, 0.0))
            self._soc_kwh += p_charge * self.eta_ch * dt

        elif net_demand_kw > 0:
            p_req       = min(net_demand_kw, self.max_p_kw)
            p_req       = min(p_req, self._prev_p + self.ramp_limit_kw)
            available   = (self._soc_kwh - self.min_e) * self.eta_dis / dt
            p_discharge = min(p_req, max(available, 0.0))
            self._soc_kwh -= p_discharge / self.eta_dis * dt

        # Self-discharge (LFP: ≈ 0.005 %/h)
        self._soc_kwh *= (1.0 - self.spec.self_discharge_hr * dt)
        self._soc_kwh  = float(np.clip(self._soc_kwh, self.min_e, self.max_e))
        self._prev_p   = p_charge if p_charge > 0 else p_discharge

        return {
            "p_charge_kw"    : p_charge,
            "p_discharge_kw" : p_discharge,
            "soc_kwh"        : self._soc_kwh,
            "soc_pct"        : self.soc_pct,
        }


# ──────────────────────────────────────────────────────────────────────────────
# 5.  ENHANCED INVERTER MODEL  (DC voltage + temperature derating)
# ──────────────────────────────────────────────────────────────────────────────

class Inverter:
    """
    Sungrow SG1100UD-20 efficiency model.

    Three physical effects are modelled:

    1. Loading-ratio efficiency curve (3-segment, unchanged from baseline).
       Below 5 % load → standby / zero output.
       5–20 % load → efficiency ramps from 96.0 % to η_euro (98.8 %).
       > 20 % load → η_euro (98.8 %) held constant.

    2. DC voltage penalty outside the optimal MPPT window.
       The inverter can track MPPT between 200–1 500 V DC.
       Outside the optimal sub-range (850–1 350 V):
         • Below 850 V : efficiency factor ramps 0.95 → 1.0
           (boost converter losses increase at low voltage).
         • Above 1 350 V: efficiency factor ramps 1.0 → 0.98
           (higher switching losses / clipping risk).
         • Below 200 V or above 1 500 V: inverter shuts off (output = 0).

    3. Ambient temperature derating above 40 °C.
       Sungrow specifies full-rated output from –25 °C to +40 °C.
       Above 40 °C: power is derated at 0.3 %/°C (–3 kW/°C per module),
       consistent with typical central-inverter datasheets.
       Output is floored at 80 % of rated to avoid unphysical negatives.
    """

    def __init__(self, spec: SungrowModular, n_modules: int):
        self.spec      = spec
        self.n_modules = n_modules
        self.rated_kw  = spec.power_module_kw * n_modules

    # ─────────────────────────────────────────────────────────────────
    def ac_power_kw(
        self,
        dc_kw  : np.ndarray,
        v_dc   : Optional[np.ndarray] = None,
        t_amb  : Optional[np.ndarray] = None,
    ) -> np.ndarray:
        """
        Convert DC input power to AC output power.

        Parameters
        ----------
        dc_kw  : DC power entering the inverter    [kW]   (array)
        v_dc   : DC string voltage at inverter input[V]   (array, optional)
        t_amb  : Ambient temperature               [°C]   (array, optional)

        Returns
        -------
        ac_kw  : AC output power                   [kW]
        """
        dc_kw = np.asarray(dc_kw, dtype=float)
        ratio = np.clip(dc_kw / max(self.rated_kw, 1.0), 0.0, 1.10)

        # ── 1. Base efficiency curve (loading ratio) ──────────────────
        eta = np.where(
            ratio < 0.05,
            0.0,
            np.where(
                ratio < 0.20,
                0.960 + (self.spec.eta_euro - 0.960) * (ratio - 0.05) / 0.15,
                self.spec.eta_euro,
            ),
        )

        # ── 2. DC voltage: MPPT window penalty ───────────────────────
        if v_dc is not None:
            v       = np.asarray(v_dc, dtype=float)
            v_min   = self.spec.v_mppt_min
            v_max   = self.spec.v_mppt_max
            v_lo    = self.spec.v_mppt_opt_lo
            v_hi    = self.spec.v_mppt_opt_hi

            v_factor = np.where(
                (v < v_min) | (v > v_max),
                0.0,                                       # outside abs limits
                np.where(
                    v < v_lo,
                    # Low-voltage sub-range: boost converter losses
                    0.95 + 0.05 * (v - v_min) / (v_lo - v_min),
                    np.where(
                        v > v_hi,
                        # High-voltage sub-range: switching / clipping losses
                        1.00 - 0.02 * (v - v_hi) / (v_max - v_hi),
                        1.0,                               # optimal range
                    ),
                ),
            )
            eta = eta * v_factor

        # ── 3. Ambient temperature derating ──────────────────────────
        if t_amb is not None:
            t        = np.asarray(t_amb, dtype=float)
            excess   = np.maximum(t - self.spec.t_derate_onset, 0.0)
            t_factor = np.maximum(
                1.0 - self.spec.derate_rate_per_c * excess, 0.80)
            eta = eta * t_factor

        return np.maximum(dc_kw * eta, 0.0)


# ──────────────────────────────────────────────────────────────────────────────
# 6.  OPTIMAL DISPATCHER  (Pyomo LP – cost-minimising multi-period dispatch)
# ──────────────────────────────────────────────────────────────────────────────

class OptimalDispatcher:
    """
    Cost-minimising battery dispatch via a full-year linear programme (LP).

    Problem formulation
    ───────────────────
    The LP is solved once for all 8 760 hours simultaneously (perfect-foresight
    optimal dispatch), which bounds the achievable savings and is the standard
    reference used in academic techno-economic assessments.

    Decision variables (per hour t):
      p_c[t]      – battery charging power        [kW]  ≥ 0
      p_d[t]      – battery discharging power      [kW]  ≥ 0
      e_grid[t]   – grid electricity import        [kW]  ≥ 0
      curtail[t]  – PV curtailment                 [kW]  ≥ 0
      soc[t]      – state-of-charge at start of t  [kWh]

    Objective – minimise annual electricity purchase cost:

        min  Σ_t  price[t] · e_grid[t] / 1 000   [€]

    Constraints:
      (i)  Energy balance (each hour):
             pv_ac[t] + p_d[t] + e_grid[t]  =  demand[t] + p_c[t] + curtail[t]

      (ii) SOC dynamics:
             soc[t+1] = soc[t] · (1 – σ) + p_c[t] · η_ch – p_d[t] / η_dis

      (iii) SOC bounds:   E_min  ≤  soc[t]  ≤  E_max
      (iv)  Power limits: 0      ≤  p_c[t]  ≤  P_max_ch
                          0      ≤  p_d[t]  ≤  P_max_dis
      (v)   Terminal SOC: soc[T] ≥  soc[0]   (prevents end-of-year depletion)

    Simultaneous charge/discharge is implicitly avoided: any charge–discharge
    round-trip wastes energy (η_rt < 1) and increases cost, so the LP solution
    naturally avoids it without binary variables.

    Solver: HiGHS (appsi_highs) via Pyomo, with GLPK/CBC fall-back.
    Typical solve time for 8 760-step LP: < 30 s on a laptop.
    """

    def __init__(
        self,
        pv           : PVArray,
        battery      : BatteryESS,
        inverter     : Inverter,
        coverage_frac: float = 0.40,
    ):
        self.pv            = pv
        self.battery       = battery
        self.inverter      = inverter
        self.coverage_frac = coverage_frac

    # ─────────────────────────────────────────────────────────────────
    @staticmethod
    def _pick_solver() -> pyo.SolverFactory:
        """Return the fastest available LP solver."""
        for name in ("appsi_highs", "highs", "glpk", "cbc"):
            try:
                s = pyo.SolverFactory(name)
                if s.available():
                    return s, name
            except Exception:
                continue
        raise RuntimeError(
            "No LP solver found.  Install HiGHS via:  pip install highspy\n"
            "or GLPK via:  sudo apt-get install glpk-utils"
        )

    # ─────────────────────────────────────────────────────────────────
    def _build_lp(
        self,
        pv_ac_arr : np.ndarray,   # [kW] PV AC output, length n
        target_arr: np.ndarray,   # [kW] energy demand to cover, length n
        prices_arr: np.ndarray,   # [€/MWh] electricity prices, length n
    ) -> pyo.ConcreteModel:
        """
        Construct the Pyomo LP model.

        All numpy arrays are converted to Python lists before being used in
        Pyomo rule functions to avoid repeated ndarray indexing overhead.
        """
        bat     = self.battery
        eta_ch  = float(bat.eta_ch)
        eta_dis = float(bat.eta_dis)
        E_min   = float(bat.min_e)
        E_max   = float(bat.max_e)
        P_ch    = float(bat.max_p_kw)
        P_dis   = float(bat.max_p_kw)
        sigma   = float(bat.spec.self_discharge_hr)   # fraction / h
        E_init  = float(bat.capacity_kwh * 0.50)      # start at 50 % SOC

        # Pre-convert to plain Python lists for rule-function speed
        pv   = pv_ac_arr.tolist()
        dem  = target_arr.tolist()
        pr   = prices_arr.tolist()
        n    = len(pv)

        m = pyo.ConcreteModel(name="BatteryOptDispatch")

        # ── Sets ──────────────────────────────────────────────────────
        m.T  = pyo.Set(initialize=range(n),     ordered=True)
        m.Ts = pyo.Set(initialize=range(n + 1), ordered=True)

        # ── Variables ─────────────────────────────────────────────────
        m.p_c     = pyo.Var(m.T,  bounds=(0.0, P_ch),  initialize=0.0)
        m.p_d     = pyo.Var(m.T,  bounds=(0.0, P_dis), initialize=0.0)
        m.e_grid  = pyo.Var(m.T,  bounds=(0.0, None),  initialize=0.0)
        m.curtail = pyo.Var(m.T,  bounds=(0.0, None),  initialize=0.0)
        m.soc     = pyo.Var(m.Ts, bounds=(E_min, E_max), initialize=E_init)

        # Fix initial SOC
        m.soc[0].fix(E_init)

        # ── Objective: minimise annual grid purchase cost [€] ─────────
        m.obj = pyo.Objective(
            expr=pyo.quicksum(pr[t] * m.e_grid[t] / 1_000.0 for t in m.T),
            sense=pyo.minimize,
        )

        # ── (i) Energy balance ────────────────────────────────────────
        def balance_rule(mdl, t):
            # Sources: PV + battery discharge + grid import
            # Sinks  : demand target + battery charge + curtailment
            return (pv[t] + mdl.p_d[t] + mdl.e_grid[t]
                    == dem[t] + mdl.p_c[t] + mdl.curtail[t])

        m.balance = pyo.Constraint(m.T, rule=balance_rule)

        # ── (ii) SOC dynamics ─────────────────────────────────────────
        def soc_rule(mdl, t):
            return (mdl.soc[t + 1]
                    == mdl.soc[t] * (1.0 - sigma)
                    + mdl.p_c[t] * eta_ch
                    - mdl.p_d[t] / eta_dis)

        m.soc_dyn = pyo.Constraint(m.T, rule=soc_rule)

        # ── (v) Terminal SOC ≥ initial SOC ───────────────────────────
        m.terminal = pyo.Constraint(expr=m.soc[n] >= E_init)

        return m

    # ─────────────────────────────────────────────────────────────────
    def run(
        self,
        weather        : pd.DataFrame,
        total_demand_kw: np.ndarray,
        operating_hours: np.ndarray,
        year           : int = 1,
        prices         : Optional[np.ndarray] = None,
    ) -> pd.DataFrame:
        """
        Run the optimal dispatch for one full year.

        Parameters
        ----------
        weather         : pd.DataFrame from load_pvgis_tmy / generate_synthetic_tmy
        total_demand_kw : Total plant demand [kW]  (8760,)
        operating_hours : Boolean mask, True = plant operating
        year            : Operational year 1-based (affects PV degradation)
        prices          : Electricity prices [€/MWh] (8760,).
                          If None, falls back to a flat 85 €/MWh price.

        Returns
        -------
        pd.DataFrame with hourly energy flows, KPIs, and PV diagnostics.
        """
        n = len(weather)

        # ── PV simulation (pvlib) ─────────────────────────────────────
        pv_dc, v_dc, pv_diag = self.pv.simulate(weather, year=year)
        t_amb = weather["temp_air"].values
        pv_ac = self.inverter.ac_power_kw(pv_dc, v_dc=v_dc, t_amb=t_amb)

        target = total_demand_kw * self.coverage_frac

        if prices is None:
            prices = np.full(n, 85.0)

        # ── Build & solve Pyomo LP ────────────────────────────────────
        print(f"  Building Pyomo LP  ({n} time steps × 5 variables)…")
        model = self._build_lp(pv_ac, target, prices)

        solver, solver_name = self._pick_solver()
        print(f"  Solver: {solver_name}  — solving…")
        result = solver.solve(model, tee=False)

        status = str(result.solver.termination_condition)
        if status not in ("optimal", "feasible"):
            raise RuntimeError(
                f"LP did not converge.  Solver status: {status}\n"
                "Check that battery sizing is consistent with demand."
            )
        print(f"  LP solved  (status: {status},  "
              f"obj = {pyo.value(model.obj):,.0f} €/yr grid cost)")

        # ── Extract optimised hourly schedules ────────────────────────
        T   = list(range(n))
        Ts  = list(range(n + 1))

        p_c_sol     = np.array([pyo.value(model.p_c[t])     for t in T])
        p_d_sol     = np.array([pyo.value(model.p_d[t])     for t in T])
        e_grid_sol  = np.array([pyo.value(model.e_grid[t])  for t in T])
        curtail_sol = np.array([pyo.value(model.curtail[t]) for t in T])
        soc_sol     = np.array([pyo.value(model.soc[t])     for t in Ts])

        # Clip numerical noise
        p_c_sol     = np.maximum(p_c_sol,    0.0)
        p_d_sol     = np.maximum(p_d_sol,    0.0)
        e_grid_sol  = np.maximum(e_grid_sol, 0.0)
        curtail_sol = np.maximum(curtail_sol,0.0)
        soc_sol     = np.clip(soc_sol, self.battery.min_e, self.battery.max_e)

        # Derived flows
        # pv_to_load = PV share that actually goes to serve demand
        #            = pv_ac – charge – curtail   (from energy balance)
        pv_to_load  = np.maximum(pv_ac - p_c_sol - curtail_sol, 0.0)
        delivered   = pv_to_load + p_d_sol        # = target - e_grid (by balance)
        unmet       = np.maximum(target - delivered - e_grid_sol, 0.0)

        # ── Build output DataFrame ────────────────────────────────────
        df = pd.DataFrame({
            "pv_dc_kw"       : pv_dc,
            "pv_ac_kw"       : pv_ac,
            "target_kw"      : target,
            "pv_to_load_kw"  : pv_to_load,
            "bat_to_load_kw" : p_d_sol,
            "p_charge_kw"    : p_c_sol,
            "p_discharge_kw" : p_d_sol,
            "e_grid_kw"      : e_grid_sol,
            "curtailed_kw"   : curtail_sol,
            "unmet_kw"       : unmet,
            "soc_kwh"        : soc_sol[:n],
            "soc_pct"        : soc_sol[:n] / self.battery.capacity_kwh * 100.0,
            "elec_price_eur_mwh": prices,
        }, index=weather.index)

        df["delivered_kw"]   = delivered
        df["actual_cov_pct"] = np.where(
            target > 0, delivered / target * 100.0, 0.0)
        df["hour_of_day"]    = np.arange(n) % 24
        df["day_of_year"]    = np.arange(n) // 24 + 1
        df["ghi_wm2"]        = weather["ghi"].values
        df["dni_wm2"]        = weather["dni"].values
        df["dhi_wm2"]        = weather["dhi"].values
        df["t_amb_c"]        = weather["temp_air"].values
        df["wind_speed_ms"]  = weather["wind_speed"].values
        df["total_demand_kw"]= total_demand_kw
        df["operating"]      = operating_hours

        # Attach key PV diagnostics
        for col in [
            "poa_effective", "poa_bifacial", "poa_front",
            "shade_fraction", "spectral_factor", "t_cell_c",
            "v_dc_v", "deg_factor", "rear_irradiance_wm2",
            "bifacial_gain_wm2",
        ]:
            if col in pv_diag.columns:
                df[col] = pv_diag[col].values

        return df




# ──────────────────────────────────────────────────────────────────────────────
# 7.  ECONOMIC MODEL  (NPV / IRR / payback + battery replacement CAPEX)
# ──────────────────────────────────────────────────────────────────────────────

class EconomicModel:
    """
    Techno-economic model for the PV + Battery subsystem.

    Key additions vs. the baseline model
    ─────────────────────────────────────
    • Battery lifetime fixed to 15 years (Tesla Megapack 2 XL datasheet).
      For a 25-year project life, a single battery replacement is costed
      at year 15 (as an actual cash outflow in the DCF stream).

    • Annual savings computed from hourly electricity prices:
        savings[y] = Σ_t  price[t] · delivered[t] / 1 000  [€/yr]
      Year-on-year values are scaled by the PV degradation factor.

    • Net Present Value (NPV)
        NPV = Σ_{y=0}^{N}  CF[y] / (1+r)^y
        CF[0] = –CAPEX_total
        CF[y] = savings[y] – OPEX[y]   for y = 1..N
        CF[15] also includes –battery_replacement_CAPEX (un-discounted outflow)

    • Internal Rate of Return (IRR) – solved via Brent's method.

    • Simple (undiscounted) payback period – fractional year when cumulative
      cash flows first turn non-negative.
    """

    BATTERY_LIFETIME_YR: int = 15   # Tesla Megapack 2 XL warranty (datasheet)

    def __init__(
        self,
        pv           : PVArray,
        battery      : BatteryESS,
        inverter     : Inverter,
        panel_spec   : JinkoTigerNeo,
        battery_spec : TeslaMegapack2XL,
        inverter_spec: SungrowModular,
        lifetime_yr    : int   = 25,
        discount_rate  : float = 0.05,
        land_eur_m2    : float = 10.0,
        packing_factor : float = 0.40,
        bos_pct        : float = 0.12,
        epc_pct        : float = 0.08,
        om_pv_pct      : float = 0.015,
        om_bat_pct     : float = 0.020,
        om_inv_pct     : float = 0.010,
        insurance_pct  : float = 0.005,
    ):
        self.pv       = pv
        self.battery  = battery
        self.inverter = inverter
        self.p_spec   = panel_spec
        self.b_spec   = battery_spec
        self.i_spec   = inverter_spec
        self.lifetime = lifetime_yr
        self.r        = discount_rate
        self.land_eur_m2 = land_eur_m2
        self.gcr      = packing_factor
        self.bos_pct  = bos_pct
        self.epc_pct  = epc_pct
        self.om_pv_pct  = om_pv_pct
        self.om_bat_pct = om_bat_pct
        self.om_inv_pct = om_inv_pct
        self.ins_pct  = insurance_pct

    # ─────────────────────────────────────────────────────────────────
    def capex(self) -> dict:
        """Initial capital expenditure breakdown [€]."""
        pv_hw  = self.pv.peak_kw * 1_000 * self.p_spec.cost_eur_per_wp
        bat_hw = self.battery.capacity_kwh * self.b_spec.cost_eur_per_kwh
        inv_hw = self.inverter.rated_kw    * self.i_spec.cost_eur_per_kw
        bos    = (pv_hw + inv_hw) * self.bos_pct
        land   = (self.pv.area_m2 / self.gcr) * self.land_eur_m2
        epc    = (pv_hw + bat_hw + inv_hw + bos) * self.epc_pct
        total  = pv_hw + bat_hw + inv_hw + bos + land + epc
        return {
            "PV panels (Jinko Tiger Neo)"   : pv_hw,
            "Battery (Tesla Megapack 2 XL)" : bat_hw,
            "Inverter (Sungrow 1+X)"        : inv_hw,
            "Balance of System (BOS)"       : bos,
            "Land"                           : land,
            "EPC"                            : epc,
            "Total CAPEX"                    : total,
        }

    def opex_annual(self) -> dict:
        """Annual operational expenditure [€/yr]."""
        cap    = self.capex()
        pv_om  = cap["PV panels (Jinko Tiger Neo)"]   * self.om_pv_pct
        bat_om = cap["Battery (Tesla Megapack 2 XL)"] * self.om_bat_pct
        inv_om = cap["Inverter (Sungrow 1+X)"]        * self.om_inv_pct
        ins    = cap["Total CAPEX"]                    * self.ins_pct
        total  = pv_om + bat_om + inv_om + ins
        return {
            "PV O&M"      : pv_om,
            "Battery O&M" : bat_om,
            "Inverter O&M": inv_om,
            "Insurance"   : ins,
            "Total OPEX"  : total,
        }

    def battery_replacement_capex(self) -> float:
        """
        Un-discounted battery replacement cost at year 15 [€].

        Tesla Megapack 2 XL warranty = 15 years.  For a 25-year project
        the battery pack is replaced once; the inverter (25-yr warranty)
        and PV panels (30-yr power warranty) are NOT replaced.
        A 10 % cost reduction vs. initial purchase is assumed (technology
        learning rate, economies of scale).
        """
        bat_hw = self.battery.capacity_kwh * self.b_spec.cost_eur_per_kwh
        return bat_hw * 0.90   # 10 % reduction on replacement

    # ─────────────────────────────────────────────────────────────────
    def annual_savings(
        self, df: pd.DataFrame, prices: np.ndarray, year: int = 1
    ) -> float:
        """
        Annual savings from displaced grid electricity [€/yr].

        Savings = Σ_t  price[t] · delivered[t] / 1 000

        where delivered[t] = pv_to_load[t] + bat_to_load[t]  [kWh/h].

        For year > 1 the delivered energy is scaled by the cumulative
        PV degradation factor (battery round-trip efficiency is assumed
        unchanged).

        Parameters
        ----------
        df     : hourly results DataFrame (from OptimalDispatcher.run, year=1)
        prices : electricity prices [€/MWh]  (8760,)
        year   : operational year  (1-based)
        """
        base = float(np.dot(prices, df["delivered_kw"].values) / 1_000.0)
        if year == 1:
            return base
        deg = ((1.0 - self.p_spec.deg_y1)
               * (1.0 - self.p_spec.deg_annual) ** (year - 1))
        return base * deg

    # ─────────────────────────────────────────────────────────────────
    def cash_flows(
        self, df: pd.DataFrame, prices: np.ndarray
    ) -> np.ndarray:
        """
        Annual net cash flows [€], indexed 0..lifetime.

        Index 0  : –Total CAPEX  (year of commissioning)
        Index y  : +annual_savings[y] – annual_OPEX    (y = 1..lifetime)
        Index 15 : additionally –battery_replacement_CAPEX
        """
        cap   = self.capex()["Total CAPEX"]
        opex  = self.opex_annual()["Total OPEX"]
        bat_r = self.battery_replacement_capex()
        cf    = np.zeros(self.lifetime + 1)
        cf[0] = -cap
        for y in range(1, self.lifetime + 1):
            cf[y] = self.annual_savings(df, prices, year=y) - opex
            if y == self.BATTERY_LIFETIME_YR:
                cf[y] -= bat_r   # battery replacement cash outflow
        return cf

    # ─────────────────────────────────────────────────────────────────
    def npv(self, df: pd.DataFrame, prices: np.ndarray) -> float:
        """
        Net Present Value [€] at the project discount rate r.

        NPV = Σ_{y=0}^{N}  CF[y] / (1 + r)^y
        """
        cf   = self.cash_flows(df, prices)
        disc = np.array([(1.0 + self.r) ** (-y)
                         for y in range(self.lifetime + 1)])
        return float(np.dot(cf, disc))

    # ─────────────────────────────────────────────────────────────────
    def irr(self, df: pd.DataFrame, prices: np.ndarray) -> float:
        """
        Internal Rate of Return [fraction, e.g. 0.12 = 12 %].

        Solves  NPV(r) = 0  via Brent's method on r ∈ (–0.5, 5.0).
        Returns NaN if the project never generates a positive NPV.
        """
        cf = self.cash_flows(df, prices)

        def _npv_at(r: float) -> float:
            disc = np.array([(1.0 + r) ** (-y) for y in range(len(cf))])
            return float(np.dot(cf, disc))

        try:
            # Brent's method requires a sign change in the bracket
            lo, hi = -0.50, 5.0
            if _npv_at(lo) * _npv_at(hi) > 0:
                return float("nan")
            return float(brentq(_npv_at, lo, hi, xtol=1e-7, maxiter=200))
        except (ValueError, RuntimeError):
            return float("nan")

    # ─────────────────────────────────────────────────────────────────
    def payback_period(
        self, df: pd.DataFrame, prices: np.ndarray
    ) -> float:
        """
        Simple (undiscounted) payback period [years].

        Returns the fractional year when cumulative cash flows first turn
        non-negative.  Returns NaN if payback is not reached within the
        project lifetime.
        """
        cf  = self.cash_flows(df, prices)
        cum = np.cumsum(cf)
        for y in range(1, len(cum)):
            if cum[y] >= 0.0:
                # Linear interpolation between year y-1 and y
                frac = -cum[y - 1] / (cum[y] - cum[y - 1])
                return float(y - 1 + frac)
        return float("nan")

    # ─────────────────────────────────────────────────────────────────
    def _annuity_factor(self) -> float:
        r, n = self.r, self.lifetime
        return (1.0 - (1.0 + r) ** (-n)) / r

    def lcoe(self, annual_energy_kwh: float) -> float:
        """
        Levelised Cost of Energy [€/MWh].

        LCOE = (CAPEX + NPV_OPEX + PV_battery_replacement)
               / Σ_{y=1}^{N} E[y] / (1+r)^y
        """
        cap      = self.capex()["Total CAPEX"]
        opex_npv = self.opex_annual()["Total OPEX"] * self._annuity_factor()
        bat_pv   = (self.battery_replacement_capex()
                    / (1.0 + self.r) ** self.BATTERY_LIFETIME_YR)
        total_disc_energy = 0.0
        for y in range(1, self.lifetime + 1):
            if y == 1:
                ey = annual_energy_kwh
            else:
                ey = (annual_energy_kwh
                      * (1.0 - self.p_spec.deg_y1)
                      * (1.0 - self.p_spec.deg_annual) ** (y - 1))
            total_disc_energy += ey / (1.0 + self.r) ** y
        return (cap + opex_npv + bat_pv) / total_disc_energy * 1_000

    # ─────────────────────────────────────────────────────────────────
    def full_summary(self, df: pd.DataFrame) -> dict:
        """Legacy summary that does not require price data."""
        annual_pv        = df["pv_ac_kw"].sum()
        annual_delivered = df["delivered_kw"].sum()
        annual_bat_dis   = df["bat_to_load_kw"].sum()
        annual_curtailed = df["curtailed_kw"].sum()
        annual_unmet     = df["unmet_kw"].sum()
        total_target     = df["target_kw"].sum()

        cap  = self.capex()
        opex = self.opex_annual()
        lcoe = self.lcoe(annual_delivered)

        actual_cov   = (annual_delivered / total_target * 100) if total_target > 0 else 0
        bat_share    = (annual_bat_dis / annual_delivered * 100) if annual_delivered > 0 else 0
        curtail_rate = (annual_curtailed / annual_pv * 100) if annual_pv > 0 else 0

        return {
            "CAPEX"       : cap,
            "Annual OPEX" : opex,
            "KPIs" : {
                "Annual PV AC generation [MWh]"  : annual_pv / 1_000,
                "Annual energy delivered [MWh]"  : annual_delivered / 1_000,
                "Battery share of delivery [%]"  : bat_share,
                "Curtailed energy [MWh]"         : annual_curtailed / 1_000,
                "Unmet demand [MWh]"             : annual_unmet / 1_000,
                "Actual coverage [%]"            : actual_cov,
                "Curtailment rate [%]"           : curtail_rate,
                "LCOE (incl. batt. replacement) [€/MWh]": lcoe,
                "Specific CAPEX [€/kWp]"         : cap["Total CAPEX"] / self.pv.peak_kw,
                "CAPEX per MWh stored [€/MWh]"   : cap["Battery (Tesla Megapack 2 XL)"]
                                                    / (self.battery.capacity_kwh / 1_000),
            },
        }

    def financial_summary(
        self, df: pd.DataFrame, prices: np.ndarray
    ) -> dict:
        """
        Return a full financial KPI dictionary, including NPV, IRR, payback.

        Parameters
        ----------
        df     : hourly dispatch results (year 1)
        prices : hourly electricity prices [€/MWh]
        """
        cf       = self.cash_flows(df, prices)
        npv_val  = self.npv(df, prices)
        irr_val  = self.irr(df, prices)
        pb_val   = self.payback_period(df, prices)
        sav_yr1  = self.annual_savings(df, prices, year=1)
        bat_repl = self.battery_replacement_capex()
        lcoe_val = self.lcoe(df["delivered_kw"].sum())
        annual_grid_cost = float(np.dot(prices, df["e_grid_kw"].values) / 1_000.0)
        annual_grid_ref  = float(np.dot(prices, df["target_kw"].values) / 1_000.0)

        return {
            "cash_flows_eur"            : cf,
            "Annual savings yr1 [€]"    : sav_yr1,
            "Annual grid cost opt [€]"  : annual_grid_cost,
            "Annual grid cost ref [€]"  : annual_grid_ref,
            "Battery replacement [€]"   : bat_repl,
            "NPV [€]"                   : npv_val,
            "NPV [M€]"                  : npv_val / 1e6,
            "IRR [%]"                   : irr_val * 100 if not np.isnan(irr_val) else float("nan"),
            "Payback period [yr]"       : pb_val,
            "LCOE [€/MWh]"             : lcoe_val,
            "Discount rate [%]"         : self.r * 100,
            "Project lifetime [yr]"     : self.lifetime,
            "Battery lifetime [yr]"     : self.BATTERY_LIFETIME_YR,
        }




