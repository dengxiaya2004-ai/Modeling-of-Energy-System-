class PVArray:
    """
    Simplified PV array model using the irradiance–temperature correction approach.
    Suitable for yield estimation in early-stage techno-economic assessment.
    For a higher-fidelity model, consider pvlib with the CEC single-diode model.
    """

    def __init__(self, panel: JinkoTigerNeo, n_panels: int,
                 tilt_deg: float = 30.0,
                 system_losses: float = 0.14):
        """
        Parameters
        ----------
        panel        : JinkoTigerNeo dataclass
        n_panels     : number of panels installed
        tilt_deg     : array tilt angle from horizontal [°] (30° typical for Seville)
        system_losses: combined losses – soiling, wiring, mismatch, availability [–]
        """
        self.panel        = panel
        self.n_panels     = n_panels
        self.tilt         = tilt_deg
        self.sys_losses   = system_losses
        self.peak_kw      = panel.pmax_stc * n_panels / 1_000
        self.area_m2      = panel.area_m2 * n_panels

    # ------------------------------------------------------------------
    def cell_temperature(self, ghi: np.ndarray, t_amb: np.ndarray) -> np.ndarray:
        """NOCT thermal model:  Tcell = Tamb + (NOCT – 20) * G / 800"""
        return t_amb + (self.panel.noct - 20.0) * ghi / 800.0

    # ------------------------------------------------------------------
    def dc_power_kw(self, ghi: np.ndarray, t_amb: np.ndarray,
                    year: int = 1) -> np.ndarray:
        """
        DC output power array [kW] accounting for:
          • irradiance ratio vs STC (1 000 W/m²)
          • temperature correction
          • annual degradation
          • balance-of-system losses
        """
        t_cell     = self.cell_temperature(ghi, t_amb)
        dT         = t_cell - 25.0                         # ΔT from STC
        temp_corr  = 1.0 + self.panel.gamma_pmax * dT
        irr_ratio  = np.clip(ghi / 1_000.0, 0.0, None)

        # Degradation factor
        if year == 1:
            deg = 1.0 - self.panel.deg_y1
        else:
            deg = (1.0 - self.panel.deg_y1) * (1.0 - self.panel.deg_annual) ** (year - 1)

        p_dc = self.peak_kw * irr_ratio * temp_corr * deg * (1.0 - self.sys_losses)
        return np.maximum(p_dc, 0.0)

    # ------------------------------------------------------------------
    def annual_summary(self) -> dict:
        return {
            "n_panels"      : self.n_panels,
            "peak_kWp"      : round(self.peak_kw, 2),
            "area_m2"       : round(self.area_m2, 1),
            "system_losses" : self.sys_losses,
            "tilt_deg"      : self.tilt,
        }


