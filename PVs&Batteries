class EconomicModel:
    """
    Levelised Cost of Electricity (LCOE) model for the PV + Battery subsystem.

    LCOE  [€/MWh] = (CAPEX + NPV_OPEX) / Σ_t  E_t / (1+r)^t

    Follows the same structure as Assignment 4 (LCoH) but adapted for
    an electricity-generating subsystem.
    """

    def __init__(self,
                 pv      : PVArray,
                 battery : BatteryESS,
                 inverter: Inverter,
                 panel_spec   : JinkoTigerNeo,
                 battery_spec : TeslaMegapack2XL,
                 inverter_spec: SungrowModular,
                 lifetime_yr     : int   = 25,
                 discount_rate   : float = 0.05,
                 land_eur_m2     : float = 10.0,
                 packing_factor  : float = 0.40,   # GCR for ground-mount array
                 bos_pct         : float = 0.12,   # BOS as % of hardware cost
                 epc_pct         : float = 0.08,   # EPC as % of subtotal
                 om_pv_pct       : float = 0.015,  # O&M as % of PV CAPEX/yr
                 om_bat_pct      : float = 0.020,  # O&M as % of battery CAPEX/yr
                 om_inv_pct      : float = 0.010,  # O&M as % of inverter CAPEX/yr
                 insurance_pct   : float = 0.005): # Insurance % of total CAPEX/yr
        self.pv           = pv
        self.battery      = battery
        self.inverter     = inverter
        self.p_spec       = panel_spec
        self.b_spec       = battery_spec
        self.i_spec       = inverter_spec
        self.lifetime     = lifetime_yr
        self.r            = discount_rate
        self.land_eur_m2  = land_eur_m2
        self.gcr          = packing_factor
        self.bos_pct      = bos_pct
        self.epc_pct      = epc_pct
        self.om_pv_pct    = om_pv_pct
        self.om_bat_pct   = om_bat_pct
        self.om_inv_pct   = om_inv_pct
        self.ins_pct      = insurance_pct

    # ------------------------------------------------------------------
    def capex(self) -> dict:
        """Return CAPEX breakdown in €."""
        pv_hw  = self.pv.peak_kw  * 1_000 * self.p_spec.cost_eur_per_wp
        bat_hw = self.battery.capacity_kwh * self.b_spec.cost_eur_per_kwh
        inv_hw = self.inverter.rated_kw * self.i_spec.cost_eur_per_kw
        bos    = (pv_hw + inv_hw) * self.bos_pct
        land   = (self.pv.area_m2 / self.gcr) * self.land_eur_m2
        epc    = (pv_hw + bat_hw + inv_hw + bos) * self.epc_pct
        total  = pv_hw + bat_hw + inv_hw + bos + land + epc
        return {
            "PV panels (Jinko Tiger Neo)"   : pv_hw,
            "Battery (Tesla Megapack 2 XL)" : bat_hw,
            "Inverter (Sungrow 1+X)"        : inv_hw,
            "Balance of System (BOS)"       : bos,
            "Land"                           : land,
            "EPC"                            : epc,
            "Total CAPEX"                    : total,
        }

    # ------------------------------------------------------------------
    def opex_annual(self) -> dict:
        """Return annual OPEX breakdown in €/yr."""
        cap = self.capex()
        pv_om  = cap["PV panels (Jinko Tiger Neo)"]   * self.om_pv_pct
        bat_om = cap["Battery (Tesla Megapack 2 XL)"] * self.om_bat_pct
        inv_om = cap["Inverter (Sungrow 1+X)"]        * self.om_inv_pct
        ins    = cap["Total CAPEX"]                    * self.ins_pct
        total  = pv_om + bat_om + inv_om + ins
        return {
            "PV O&M"      : pv_om,
            "Battery O&M" : bat_om,
            "Inverter O&M": inv_om,
            "Insurance"   : ins,
            "Total OPEX"  : total,
        }

    # ------------------------------------------------------------------
    def _annuity_factor(self) -> float:
        r, n = self.r, self.lifetime
        return (1 - (1 + r) ** (-n)) / r

    def npv_opex(self) -> float:
        return self.opex_annual()["Total OPEX"] * self._annuity_factor()

    # ------------------------------------------------------------------
    def lcoe(self, annual_energy_kwh: float) -> float:
        """
        Levelised Cost of Electricity [€/MWh].
        Uses discounted lifetime energy with annual PV degradation.
        """
        cap      = self.capex()["Total CAPEX"]
        opex_npv = self.npv_opex()

        total_disc_energy = 0.0
        for y in range(1, self.lifetime + 1):
            if y == 1:
                ey = annual_energy_kwh
            else:
                ey = (annual_energy_kwh
                      * (1 - self.p_spec.deg_y1)
                      * (1 - self.p_spec.deg_annual) ** (y - 1))
            total_disc_energy += ey / (1 + self.r) ** y

        return (cap + opex_npv) / total_disc_energy * 1_000  # €/MWh

    # ------------------------------------------------------------------
    def full_summary(self, df: pd.DataFrame) -> dict:
        """Compile complete techno-economic KPI dictionary from simulation results."""
        annual_pv        = df["pv_ac_kw"].sum()          # kWh
        annual_delivered = df["delivered_kw"].sum()       # kWh
        annual_bat_dis   = df["bat_to_load_kw"].sum()     # kWh
        annual_curtailed = df["curtailed_kw"].sum()        # kWh
        annual_unmet     = df["unmet_kw"].sum()            # kWh
        total_target     = df["target_kw"].sum()           # kWh

        cap  = self.capex()
        opex = self.opex_annual()
        lcoe = self.lcoe(annual_delivered)

        solar_share  = (annual_pv / total_target * 100) if total_target > 0 else 0.0
        actual_cov   = (annual_delivered / total_target * 100) if total_target > 0 else 0.0
        bat_share    = (annual_bat_dis / annual_delivered * 100) if annual_delivered > 0 else 0.0
        curtail_rate = (annual_curtailed / annual_pv * 100) if annual_pv > 0 else 0.0

        return {
            "CAPEX"  : cap,
            "Annual OPEX" : opex,
            "KPIs" : {
                "Annual PV generation [MWh]"    : annual_pv / 1_000,
                "Annual energy delivered [MWh]" : annual_delivered / 1_000,
                "Battery share of delivery [%]" : bat_share,
                "Curtailed energy [MWh]"        : annual_curtailed / 1_000,
                "Unmet demand [MWh]"            : annual_unmet / 1_000,
                "Solar share [%]"               : solar_share,
                "Actual coverage [%]"           : actual_cov,
                "LCOE [€/MWh]"                  : lcoe,
                "Specific CAPEX [€/kWp]"        : cap["Total CAPEX"] / self.pv.peak_kw,
                "CAPEX per MWh stored [€/MWh]"  : cap["Battery (Tesla Megapack 2 XL)"]
                                                   / (self.battery.capacity_kwh / 1_000),
            },
        }


# ──────────────────────────────────────────────────────────────────────────────
# 7.  WEATHER DATA HELPERS
# ──────────────────────────────────────────────────────────────────────────────

def generate_synthetic_tmy(lat: float = 37.4, lon: float = -5.9,
                            seed: int = 42) -> Tuple[np.ndarray, np.ndarray]:
    """
    Generate a synthetic Typical Meteorological Year for Seville, Spain.
    Annual GHI ≈ 1 850 kWh/m²  |  Mean temperature ≈ 18.5 °C

    NOTE: This is a simplified model for development/testing purposes.
    For the final project report, always use real PVGIS TMY data.
    Download from: https://re.jrc.ec.europa.eu/pvg_tools/en/#TMY
    (Seville: lat = 37.39, lon = –5.99)
    """
    rng = np.random.default_rng(seed)
    t   = np.arange(8_760)
    hod = t % 24           # hour of day
    doy = t // 24 + 1      # day of year  (1–365)

    # Solar geometry (simplified, no equation of time)
    decl_rad = np.radians(23.45 * np.sin(np.radians(360 / 365 * (doy - 81))))
    ha_rad   = np.radians((hod - 12.0) * 15.0)
    lat_r    = np.radians(lat)
    elev     = np.degrees(np.arcsin(
        np.sin(lat_r) * np.sin(decl_rad)
        + np.cos(lat_r) * np.cos(decl_rad) * np.cos(ha_rad)))

    # Clear-sky GHI
    ghi_cs = np.where(elev > 0.0, 1_000.0 * np.sin(np.radians(elev)), 0.0)

    # Seasonal cloud cover (Seville: mostly clear, rainier in winter)
    cloud_seasonal = 0.78 + 0.14 * np.sin(np.radians(360 / 365 * (doy - 180)))
    cloud_noise    = np.clip(rng.normal(1.0, 0.12, 8_760), 0.25, 1.0)
    ghi = np.maximum(ghi_cs * cloud_seasonal * cloud_noise, 0.0)

    # Temperature (Seville: mean 18.5 °C, σ seasonal ≈ 9 °C)
    t_seasonal = 18.5 + 9.0 * np.sin(np.radians(360 / 365 * (doy - 75)))
    t_daily    = 4.0 * np.sin(np.radians(360 / 24 * (hod - 5)))
    t_amb      = t_seasonal + t_daily + rng.normal(0.0, 1.2, 8_760)

    return ghi, t_amb


def load_pvgis_tmy(csv_path: str) -> Tuple[np.ndarray, np.ndarray]:
    """
    Load a real TMY from a PVGIS CSV export file.

    PVGIS files have a variable-length text header before the data block.
    This function finds the header row automatically by scanning for the
    line that contains 'G(h)' (the GHI column label), so it works regardless
    of whether PVGIS prepended 16, 17, or a different number of header lines.

    Expected data columns (PVGIS TMY standard output):
      'G(h)'  – Global Horizontal Irradiance  [W/m²]
      'T2m'   – Ambient temperature at 2 m    [°C]
    """
    # Find the row index of the column-header line
    header_row = None
    with open(csv_path, "r", encoding="utf-8", errors="replace") as fh:
        for idx, line in enumerate(fh):
            if "G(h)" in line:
                header_row = idx
                break

    if header_row is None:
        raise ValueError(
            f"Could not find 'G(h)' column in '{csv_path}'.\n"
            "Make sure this is a PVGIS TMY CSV file.\n"
            "Download from: https://re.jrc.ec.europa.eu/pvg_tools/en/#TMY"
        )

    df = pd.read_csv(csv_path, skiprows=header_row, nrows=8_760)

    # Normalise column names (strip whitespace)
    df.columns = df.columns.str.strip()

    if "G(h)" not in df.columns or "T2m" not in df.columns:
        raise ValueError(
            f"Expected columns 'G(h)' and 'T2m' not found.\n"
            f"Columns present: {list(df.columns)}"
        )

    ghi  = df["G(h)"].to_numpy(dtype=float)
    tamb = df["T2m"].to_numpy(dtype=float)
    return ghi, tamb


