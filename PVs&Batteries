def load_pvgis_tmy(csv_path: str) -> pd.DataFrame:
    """
    Load a PVGIS TMY CSV export and return a tidy DataFrame.

    Returns
    -------
    pd.DataFrame with DatetimeIndex (UTC) and columns:
      'ghi'               [W/m²]  – Global Horizontal Irradiance
      'dni'               [W/m²]  – Direct Normal Irradiance
      'dhi'               [W/m²]  – Diffuse Horizontal Irradiance
      'temp_air'          [°C]    – Ambient temperature at 2 m
      'wind_speed'        [m/s]   – Wind speed at 10 m
      'pressure'          [Pa]    – Surface pressure
      'relative_humidity' [%]     – Relative humidity (if present)

    Notes
    -----
    PVGIS CSV files have a variable-length metadata header before the data
    block.  This function auto-detects the header row by scanning for the
    line containing 'G(h)'.  Exactly 8 760 data rows are read (skip footer).
    The PVGIS time column ('YYYYMMDD:HHMM') is parsed into a UTC DatetimeIndex
    so that pvlib solar-position calculations are temporally accurate.
    """
    # ── Locate the header row ─────────────────────────────────────────
    header_row = None
    with open(csv_path, "r", encoding="utf-8", errors="replace") as fh:
        for idx, line in enumerate(fh):
            if "G(h)" in line:
                header_row = idx
                break

    if header_row is None:
        raise ValueError(
            f"Could not find 'G(h)' column in '{csv_path}'.\n"
            "Make sure this is a PVGIS TMY CSV.\n"
            "Download: https://re.jrc.ec.europa.eu/pvg_tools/en/#TMY"
        )

    # ── Read exactly 8 760 hourly rows (skip footer metadata) ─────────
    raw = pd.read_csv(csv_path, skiprows=header_row, nrows=8_760)
    raw.columns = raw.columns.str.strip()

    # ── Validate minimum required columns ─────────────────────────────
    if "G(h)" not in raw.columns or "T2m" not in raw.columns:
        raise ValueError(
            f"Expected columns 'G(h)' and 'T2m' not found.\n"
            f"Columns present: {list(raw.columns)}"
        )

    # ── Parse PVGIS timestamps ('YYYYMMDD:HHMM') → UTC DatetimeIndex ──
    time_col = raw.columns[0]   # typically 'time(UTC)'
    try:
        times = pd.to_datetime(
            raw[time_col].astype(str), format="%Y%m%d:%H%M", utc=True)
    except Exception:
        # Fallback: assign synthetic timestamps for a non-leap year
        print("  ⚠  Could not parse timestamps; using synthetic 2019 index.")
        times = pd.date_range("2019-01-01", periods=8_760, freq="h", tz="UTC")

    # ── Map PVGIS column names → internal names ────────────────────────
    col_map = {
        "G(h)" : "ghi",
        "Gb(n)": "dni",        # Direct Normal Irradiance
        "Gd(h)": "dhi",        # Diffuse Horizontal Irradiance
        "T2m"  : "temp_air",
        "WS10m": "wind_speed",
        "SP"   : "pressure",
        "RH"   : "relative_humidity",
    }

    out = pd.DataFrame(index=times)
    for pvgis_col, our_col in col_map.items():
        if pvgis_col in raw.columns:
            out[our_col] = raw[pvgis_col].to_numpy(dtype=float)

    # ── Provide sensible defaults for optional columns ─────────────────
    if "dni" not in out.columns:
        # Rough estimate via the Erbs kt decomposition (see generate_synthetic_tmy)
        print("  ⚠  'Gb(n)' (DNI) not found in CSV; estimating from GHI.")
        ghi = out["ghi"].clip(lower=0)
        kt  = (ghi / ghi.replace(0, np.nan)).fillna(0).clip(0, 1)
        dhi_frac = np.where(
            kt <= 0.22, 1.0 - 0.09 * kt,
            np.where(kt <= 0.80,
                     0.9511 - 0.1604*kt + 4.388*kt**2
                     - 16.638*kt**3 + 12.336*kt**4, 0.165))
        out["dhi"] = (ghi * dhi_frac).clip(lower=0)
        solpos = SEVILLE.get_solarposition(times)
        cos_z  = np.cos(np.radians(solpos["apparent_zenith"].values))
        out["dni"] = np.where(
            cos_z > 0.02, (ghi.values - out["dhi"].values) / cos_z, 0.0)
        out["dni"] = out["dni"].clip(lower=0)
    if "dhi" not in out.columns:
        print("  ⚠  'Gd(h)' (DHI) not found in CSV; estimating from GHI.")
        out["dhi"] = (out["ghi"] * 0.15).clip(lower=0)
    if "wind_speed" not in out.columns:
        print("  ⚠  'WS10m' not found; defaulting wind speed to 1.0 m/s.")
        out["wind_speed"] = 1.0
    if "pressure" not in out.columns:
        print("  ⚠  'SP' (pressure) not found; using ISA sea-level 101 325 Pa.")
        out["pressure"] = 101_325.0

    # ── Clip irradiance to physical bounds ────────────────────────────
    for col in ("ghi", "dni", "dhi"):
        out[col] = out[col].clip(lower=0.0)

    print(f"  Loaded {len(out)} hourly rows | "
          f"GHI={out['ghi'].sum()/1000:.0f} kWh/m² | "
          f"DNI={out['dni'].sum()/1000:.0f} kWh/m² | "
          f"T_mean={out['temp_air'].mean():.1f} °C | "
          f"WS_mean={out['wind_speed'].mean():.1f} m/s")
    return out


def generate_synthetic_tmy(lat: float = 37.39, lon: float = -5.99,
                            seed: int = 42) -> pd.DataFrame:
    """
    Generate a synthetic Typical Meteorological Year for Seville.
    Returns the same column schema as load_pvgis_tmy().

    NOTE: for-development/testing only. Use real PVGIS data for reports.
    """
    rng = np.random.default_rng(seed)
    times = pd.date_range("2019-01-01", periods=8_760, freq="h", tz="UTC")
    t   = np.arange(8_760)
    hod = t % 24
    doy = t // 24 + 1

    # ── Solar geometry (simplified, no equation of time) ──────────────
    decl_rad = np.radians(23.45 * np.sin(np.radians(360 / 365 * (doy - 81))))
    ha_rad   = np.radians((hod - 12.0) * 15.0)
    lat_r    = np.radians(lat)
    sin_elev = (np.sin(lat_r) * np.sin(decl_rad)
                + np.cos(lat_r) * np.cos(decl_rad) * np.cos(ha_rad))
    elev     = np.degrees(np.arcsin(np.clip(sin_elev, -1, 1)))

    ghi_cs = np.where(elev > 0.0, 1_000.0 * sin_elev, 0.0)
    cloud_seasonal = 0.78 + 0.14 * np.sin(np.radians(360 / 365 * (doy - 180)))
    cloud_noise    = np.clip(rng.normal(1.0, 0.12, 8_760), 0.25, 1.0)
    ghi = np.maximum(ghi_cs * cloud_seasonal * cloud_noise, 0.0)

    # ── Erbs GHI → DHI / DNI decomposition ───────────────────────────
    kt = np.where(ghi_cs > 10, ghi / np.maximum(ghi_cs, 1e-3), 0.0)
    dhi_frac = np.where(
        kt <= 0.22, 1.0 - 0.09 * kt,
        np.where(kt <= 0.80,
                 0.9511 - 0.1604*kt + 4.388*kt**2
                 - 16.638*kt**3 + 12.336*kt**4, 0.165))
    dhi = ghi * dhi_frac
    dni = np.where(sin_elev > 0.02, (ghi - dhi) / sin_elev, 0.0)

    # ── Temperature (Seville: mean ≈ 18.5 °C) ────────────────────────
    t_seasonal = 18.5 + 9.0 * np.sin(np.radians(360 / 365 * (doy - 75)))
    t_daily    = 4.0  * np.sin(np.radians(360 / 24  * (hod - 5)))
    t_amb      = t_seasonal + t_daily + rng.normal(0.0, 1.2, 8_760)

    # ── Wind speed (Weibull with mean ≈ 3.5 m/s) ─────────────────────
    wind_speed = np.maximum(rng.weibull(2.0, 8_760) * 3.5, 0.3)

    # ── Pressure (near sea-level, slight seasonal variation) ──────────
    pressure = 101_000.0 + 500.0 * np.sin(np.radians(360 / 365 * doy))

    df = pd.DataFrame({
        "ghi"        : ghi.clip(0),
        "dni"        : dni.clip(0),
        "dhi"        : dhi.clip(0),
        "temp_air"   : t_amb,
        "wind_speed" : wind_speed,
        "pressure"   : pressure,
    }, index=times)
    return df


def generate_spain_electricity_prices(
    n_hours: int     = 8_760,
    base_eur_mwh: float = 85.0,
    seed: int        = 42,
) -> np.ndarray:
    """
    Generate a representative Spanish OMIE day-ahead electricity price profile.

    The profile is calibrated to Iberian market behaviour (2022–2024 data):

    Daily shape
    ───────────
    Night valley  (00–06 h) : –30 €/MWh  from base  (low industrial demand)
    Morning ramp  (07–09 h) : +15 €/MWh             (industrial start-up)
    Midday dip    (10–14 h) : –25 €/MWh             (solar over-production)
    Afternoon     (15–17 h) : +5  €/MWh             (moderate demand)
    Evening peak  (18–21 h) : +40 €/MWh             (no solar, high demand)
    Late night    (22–23 h) : –25 €/MWh             (demand drop)

    Seasonal shift
    ──────────────
    +20 €/MWh in January (high gas use), –20 €/MWh in July (peak solar).

    Stochastic component
    ────────────────────
    Day-to-day volatility  σ ≈ 12 €/MWh  (gas price swings, hydrology).
    Intra-day noise        σ ≈  4 €/MWh  (demand uncertainty).

    Prices are clipped to [5, 300] €/MWh (physical market bounds).

    Parameters
    ----------
    n_hours     : number of hourly values (default 8 760 = 1 yr)
    base_eur_mwh: long-run average price  (default 85 €/MWh)
    seed        : random seed for reproducibility

    Returns
    -------
    prices : np.ndarray, shape (n_hours,)  [€/MWh]
    """
    rng = np.random.default_rng(seed)
    hod = np.arange(n_hours) % 24           # hour-of-day 0–23
    doy = np.arange(n_hours) // 24 + 1     # day-of-year 1–365

    # Daily shape
    shape = np.select(
        condlist=[hod < 7, hod < 10, hod < 15, hod < 18, hod < 22],
        choicelist=[-30.0, +15.0, -25.0, +5.0, +40.0],
        default=-25.0,   # 22–23 h
    )

    # Seasonal component: peak in Jan (doy≈15), trough in Jul (doy≈196)
    seasonal = 20.0 * np.cos(2.0 * np.pi * (doy - 15) / 365.0)

    # Day-to-day market volatility (same value for all 24 hours of a day)
    n_days   = n_hours // 24 + 1
    day_noise = np.repeat(rng.normal(0.0, 12.0, n_days), 24)[:n_hours]

    # Intra-day noise
    hour_noise = rng.normal(0.0, 4.0, n_hours)

    prices = base_eur_mwh + shape + seasonal + day_noise + hour_noise
    return np.clip(prices, 5.0, 300.0).astype(float)


