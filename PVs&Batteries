class BatteryESS:
    """
    Rule-based operational model for the Tesla Megapack 2 XL battery system.
    One-hour time resolution.

    Dispatch priority (charging)  : PV surplus → battery
    Dispatch priority (discharging): battery → unmet demand
    """

    def __init__(self, spec: TeslaMegapack2XL, n_units: int):
        self.spec     = spec
        self.n_units  = n_units

        self.capacity_kwh = spec.energy_kwh * n_units
        self.max_p_kw     = spec.power_kw   * n_units
        self.eta_ch       = spec.charge_eta
        self.eta_dis      = spec.discharge_eta

        self.min_e = self.capacity_kwh * spec.min_soc
        self.max_e = self.capacity_kwh * spec.max_soc

        # Ramp limit: 20 % of max power per hour (conservative)
        self.ramp_limit_kw = self.max_p_kw * 0.20

        self._soc_kwh  = self.capacity_kwh * 0.50   # start at 50 %
        self._prev_p   = 0.0                          # previous dispatch

    # ------------------------------------------------------------------
    @property
    def soc_kwh(self) -> float:
        return self._soc_kwh

    @property
    def soc_pct(self) -> float:
        return self._soc_kwh / self.capacity_kwh * 100.0

    # ------------------------------------------------------------------
    def reset(self, initial_soc: float = 0.50):
        self._soc_kwh = self.capacity_kwh * initial_soc
        self._prev_p  = 0.0

    # ------------------------------------------------------------------
    def step(self, net_demand_kw: float, dt: float = 1.0) -> dict:
        """
        Simulate one time-step.

        Parameters
        ----------
        net_demand_kw : positive = need to discharge; negative = surplus (charge)
        dt            : time-step length [h], default 1 h

        Returns
        -------
        dict with keys: p_charge, p_discharge, soc_kwh, soc_pct
        """
        p_charge = p_discharge = 0.0

        if net_demand_kw < 0:
            # ── Charging ────────────────────────────────────────────────
            surplus = -net_demand_kw
            p_req   = min(surplus, self.max_p_kw)

            # Ramp constraint
            p_req = min(p_req, self._prev_p + self.ramp_limit_kw)

            # Energy headroom in battery
            headroom_kw = (self.max_e - self._soc_kwh) / (self.eta_ch * dt)
            p_charge    = min(p_req, max(headroom_kw, 0.0))

            self._soc_kwh += p_charge * self.eta_ch * dt

        elif net_demand_kw > 0:
            # ── Discharging ─────────────────────────────────────────────
            p_req = min(net_demand_kw, self.max_p_kw)

            # Ramp constraint
            p_req = min(p_req, self._prev_p + self.ramp_limit_kw)

            # Available energy
            available_kw = (self._soc_kwh - self.min_e) * self.eta_dis / dt
            p_discharge  = min(p_req, max(available_kw, 0.0))

            self._soc_kwh -= p_discharge / self.eta_dis * dt

        # Self-discharge
        self._soc_kwh *= (1.0 - self.spec.self_discharge_hr * dt)
        self._soc_kwh  = float(np.clip(self._soc_kwh, self.min_e, self.max_e))

        self._prev_p = p_charge if p_charge > 0 else p_discharge

        return {
            "p_charge_kw"    : p_charge,
            "p_discharge_kw" : p_discharge,
            "soc_kwh"        : self._soc_kwh,
            "soc_pct"        : self.soc_pct,
        }


