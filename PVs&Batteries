def main(pvgis_path: Optional[str] = None):
    SEP = "─" * 72

    # ── Component specs ───────────────────────────────────────────────
    panel_spec    = JinkoTigerNeo()
    battery_spec  = TeslaMegapack2XL()
    inverter_spec = SungrowModular()

    # ── System sizing ─────────────────────────────────────────────────
    TOTAL_MW      = 10.0
    COVERAGE      = 0.40
    TARGET_MW     = TOTAL_MW * COVERAGE          # 4 MW
    STORAGE_HRS   = 4.0
    PV_PEAK_MWP   = 8.5                          # MWp (oversized for battery fill)
    BAT_ENERGY_KWH = TARGET_MW * 1_000 * STORAGE_HRS   # 16 000 kWh
    BAT_POWER_KW   = TARGET_MW * 1_000                  # 4 000 kW

    n_panels = int(np.ceil(PV_PEAK_MWP * 1e6 / panel_spec.pmax_stc))
    n_bat    = battery_spec.units_needed(BAT_ENERGY_KWH, BAT_POWER_KW)
    n_inv    = inverter_spec.modules_needed(PV_PEAK_MWP * 1_000)

    # String configuration: Sungrow optimal MPPT 850–1350 V
    N_SERIES = 20

    pv_system  = PVArray(panel_spec, n_panels, n_series=N_SERIES)
    bat_system = BatteryESS(battery_spec, n_bat)
    inv_system = Inverter(inverter_spec, n_inv)

    # ── Print sizing ──────────────────────────────────────────────────
    print(f"\n{SEP}")
    print(f"  MJ2438 – PV + Battery Subsystem  |  Seville, Spain")
    print(f"  Physical model  : pvlib {pvlib.__version__}  "
          f"(Hay-Davies, Faiman, SAPM spectral, bifacial, row shading)")
    print(f"  Dispatch model  : Pyomo LP (full-year, cost-minimising)")
    print(f"  Financial model : NPV / IRR / payback, battery repl. @ yr 15")
    print(f"{SEP}")
    print(f"\n  COMPONENT SIZING")
    print(f"  {'PV Array':<22}: {n_panels:,} panels × {panel_spec.pmax_stc:.0f} W  "
          f"= {pv_system.peak_kw/1000:.2f} MWp  "
          f"(area {pv_system.area_m2/1e4:.2f} ha)")
    print(f"  {'Strings':<22}: {N_SERIES} panels/string × "
          f"{panel_spec.vmp_stc:.1f} V = "
          f"{N_SERIES*panel_spec.vmp_stc:.0f} V nominal DC")
    print(f"  {'Battery':<22}: {n_bat} × Tesla Megapack 2 XL  "
          f"= {n_bat*battery_spec.energy_kwh/1000:.1f} MWh  "
          f"| {n_bat*battery_spec.power_kw/1000:.2f} MW  "
          f"(RTE = {battery_spec.rte*100:.1f} %, lifetime = "
          f"{EconomicModel.BATTERY_LIFETIME_YR} yr)")
    print(f"  {'Inverter':<22}: {n_inv} × Sungrow 1.1 MW  "
          f"= {n_inv*inverter_spec.power_module_kw/1000:.1f} MW")

    # ── Weather data ──────────────────────────────────────────────────
    weather_file = pvgis_path or TMY_FILE
    try:
        print(f"\n  Loading PVGIS TMY: {weather_file}")
        weather = load_pvgis_tmy(weather_file)
        print(f"  Weather source : PVGIS TMY CSV  ← {weather_file}")
    except FileNotFoundError:
        print(f"\n  ⚠  '{weather_file}' not found — using synthetic TMY.")
        print(f"  Set TMY_FILE at top of script to your PVGIS CSV filename.")
        weather = generate_synthetic_tmy()
        print(f"  Weather source : Synthetic (Seville 37.39°N, "
              f"GHI≈{weather['ghi'].sum()/1000:.0f} kWh/m²)")

    # ── Electricity prices (Spanish OMIE representative profile) ──────
    print(f"\n  Generating Spanish OMIE electricity price profile…")
    prices = generate_spain_electricity_prices(n_hours=len(weather))
    print(f"  Price profile  : mean = {prices.mean():.0f} €/MWh  "
          f"| min = {prices.min():.0f}  | max = {prices.max():.0f} €/MWh")

    # ── Demand profile (local operating hours) ────────────────────────
    local_hour = weather.index.tz_convert("Europe/Madrid").hour
    op_mask    = (local_hour >= 8) & (local_hour < 18)
    demand_kw  = np.where(op_mask, TOTAL_MW * 1_000, 0.0)

    # ── Optimal dispatch (Pyomo LP) ───────────────────────────────────
    dispatcher = OptimalDispatcher(pv_system, bat_system, inv_system, COVERAGE)
    print(f"\n  Running year-1 optimal dispatch…")
    df = dispatcher.run(weather, demand_kw, op_mask, year=1, prices=prices)

    # ── Economic & financial analysis ─────────────────────────────────
    econ    = EconomicModel(pv_system, bat_system, inv_system,
                            panel_spec, battery_spec, inverter_spec)
    summary = econ.full_summary(df)
    fin     = econ.financial_summary(df, prices)

    # ── Print results ─────────────────────────────────────────────────
    print(f"\n{SEP}")
    print(f"  CAPEX BREAKDOWN")
    print(f"{SEP}")
    total_cap = summary["CAPEX"]["Total CAPEX"]
    for k, v in summary["CAPEX"].items():
        bar = "█" * int(v / total_cap * 28)
        print(f"  {k:<40}: €{v:>12,.0f}  {bar}")

    print(f"\n{SEP}")
    print(f"  ANNUAL OPEX")
    print(f"{SEP}")
    for k, v in summary["Annual OPEX"].items():
        print(f"  {k:<40}: €{v:>10,.0f} / yr")

    print(f"\n{SEP}")
    print(f"  KEY PERFORMANCE INDICATORS")
    print(f"{SEP}")
    for k, v in summary["KPIs"].items():
        print(f"  {k:<50}: {v:>10.2f}")

    print(f"\n{SEP}")
    print(f"  FINANCIAL ANALYSIS  (r = {fin['Discount rate [%]']:.1f} %, "
          f"lifetime = {fin['Project lifetime [yr]']} yr, "
          f"battery replaced at yr {fin['Battery lifetime [yr]']})")
    print(f"{SEP}")
    print(f"  {'Annual savings (yr 1)':<45}: "
          f"€{fin['Annual savings yr1 [€]']:>12,.0f} / yr")
    print(f"  {'Optimised grid cost (yr 1)':<45}: "
          f"€{fin['Annual grid cost opt [€]']:>12,.0f} / yr")
    print(f"  {'Reference grid cost (no system)':<45}: "
          f"€{fin['Annual grid cost ref [€]']:>12,.0f} / yr")
    print(f"  {'Battery replacement CAPEX (yr 15)':<45}: "
          f"€{fin['Battery replacement [€]']:>12,.0f}")
    print(f"  {'Net Present Value (NPV)':<45}: "
          f"€{fin['NPV [€]']:>12,.0f}   ({fin['NPV [M€]']:.2f} M€)")
    irr_str = f"{fin['IRR [%]']:.2f} %" if not np.isnan(fin["IRR [%]"]) else "n/a"
    pb_str  = f"{fin['Payback period [yr]']:.1f} yr" if not np.isnan(fin["Payback period [yr]"]) else "n/a (>25 yr)"
    print(f"  {'Internal Rate of Return (IRR)':<45}: {irr_str:>12}")
    print(f"  {'Simple payback period':<45}: {pb_str:>12}")
    print(f"  {'LCOE (incl. battery replacement)':<45}: "
          f"{fin['LCOE [€/MWh]']:>10.1f} €/MWh")

    # ── pvlib-specific diagnostics ────────────────────────────────────
    print(f"\n{SEP}")
    print(f"  PHYSICAL MODEL DIAGNOSTICS  (pvlib, year 1)")
    print(f"{SEP}")
    day_mask = df["ghi_wm2"] > 20
    if "spectral_factor" in df.columns:
        sf_mean = df.loc[day_mask, "spectral_factor"].mean()
        print(f"  Mean spectral factor (daytime)      : {sf_mean:.4f}")
    if "shade_fraction" in df.columns:
        sh_mean = df.loc[day_mask, "shade_fraction"].mean()
        print(f"  Mean beam-shade fraction (daytime)  : {sh_mean:.4f}  "
              f"({sh_mean*100:.2f} % of beam irradiance)")
    if "bifacial_gain_wm2" in df.columns:
        bf_ann  = df["bifacial_gain_wm2"].sum() / 1_000
        bf_pct  = bf_ann / (df["poa_front"].sum() / 1_000) * 100 if "poa_front" in df else 0
        print(f"  Annual bifacial rear gain           : {bf_ann:.1f} kWh/m²  "
              f"({bf_pct:.1f} % of front POA)")
    if "t_cell_c" in df.columns:
        tc_mean = df.loc[day_mask, "t_cell_c"].mean()
        tc_max  = df["t_cell_c"].max()
        print(f"  Mean / max cell temperature         : "
              f"{tc_mean:.1f} °C  /  {tc_max:.1f} °C")
    if "v_dc_v" in df.columns:
        vd_mean = df.loc[day_mask, "v_dc_v"].mean()
        vd_min  = df.loc[day_mask, "v_dc_v"].min()
        print(f"  Mean / min DC voltage (daytime)     : "
              f"{vd_mean:.0f} V  /  {vd_min:.0f} V")
    if "deg_factor" in df.columns:
        print(f"  Degradation factor  (start / end)   : "
              f"{df['deg_factor'].iloc[0]:.4f}  /  {df['deg_factor'].iloc[-1]:.4f}")
    print(f"\n{SEP}\n")

    # ── Save hourly results ───────────────────────────────────────────
    df.to_csv("hourly_results.csv", index=True)
    print("  → Hourly results saved: hourly_results.csv")

    # ── Plots ─────────────────────────────────────────────────────────
    plot_system_results(
        df, summary,
        pv_peak_mwp  = pv_system.peak_kw / 1_000,
        bat_mwh      = bat_system.capacity_kwh / 1_000,
        n_bat_units  = n_bat,
    )

    plot_financial_results(fin, summary, prices, df)

    # ── Sensitivity analysis ──────────────────────────────────────────
    print("  Running 2-D sensitivity analysis…")
    annual_del = df["delivered_kw"].sum()
    pv_g, bat_g, lcoe_m, capex_m = sensitivity_analysis(
        base_pv_mwp            = pv_system.peak_kw / 1_000,
        base_bat_mwh           = bat_system.capacity_kwh / 1_000,
        panel_spec             = panel_spec,
        battery_spec           = battery_spec,
        inverter_spec          = inverter_spec,
        base_annual_energy_kwh = annual_del,
    )
    plot_sensitivity_results(
        pv_g, bat_g, lcoe_m, capex_m,
        pv_system.peak_kw / 1_000,
        bat_system.capacity_kwh / 1_000,
    )

    return df, summary, fin, econ




